<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>TILIMANITELIMA - Pro</title>

<!-- Tailwind CSS -->
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.3.2/dist/tailwind.min.css" rel="stylesheet">

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

<style>
  html, body { height: 100%; margin: 0; }
  #map { height: 100%; width: 100%; }
  .driver-marker { width: 35px; cursor: pointer; }
  .form-floating { 
    position: absolute; 
    top: 10%; 
    left: 50%; 
    transform: translateX(-50%);
    background: rgba(255,255,255,0.9); 
    border-radius: 12px; 
    padding: 16px; 
    max-width: 90%; 
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }
</style>
</head>
<body>

<!-- Carte plein écran -->
<div id="map"></div>

<!-- Formulaire flottant -->
<div class="form-floating flex flex-col gap-2">
  <input id="name" placeholder="Nom" class="border p-2 rounded w-full">
  <input id="phone" placeholder="Téléphone" class="border p-2 rounded w-full">
  <input id="departure" placeholder="Lieu de départ" class="border p-2 rounded w-full">
  <input id="destination" placeholder="Destination" class="border p-2 rounded w-full">
  <button id="orderBtn" class="bg-blue-600 text-white py-2 px-4 rounded w-full hover:bg-blue-700 mt-2">
    Réserver maintenant
  </button>
</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
// Initialisation de la carte
var map = L.map('map').setView([12.6392, -8.0029], 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

// Icône chauffeurs
var driverIcon = L.icon({
  iconUrl: 'https://img.icons8.com/emoji/48/motorcycle-emoji.png',
  iconSize: [35, 35]
});

var drivers = [];

// Créer chauffeurs animés autour de l'utilisateur
function spawnDrivers(lat, lon, count=8){
  for(let i=0;i<count;i++){
    const offsetLat = (Math.random() - 0.5)/100;
    const offsetLon = (Math.random() - 0.5)/100;
    let marker = L.marker([lat + offsetLat, lon + offsetLon], {icon: driverIcon})
      .addTo(map)
      .bindPopup("Chauffeur proche"); // popup info chauffeur
    drivers.push(marker);
  }
}

// Déplacer chauffeurs aléatoirement
function animateDrivers(){
  drivers.forEach(marker => {
    const lat = marker.getLatLng().lat + (Math.random()-0.5)/500;
    const lon = marker.getLatLng().lng + (Math.random()-0.5)/500;
    marker.setLatLng([lat, lon]);
  });
}
setInterval(animateDrivers, 2000);

// Géolocalisation utilisateur
var userLat = 12.6392, userLon = -8.0029; // Bamako par défaut
if(navigator.geolocation){
  navigator.geolocation.getCurrentPosition(function(pos){
    userLat = pos.coords.latitude;
    userLon = pos.coords.longitude;
    L.marker([userLat, userLon]).addTo(map).bindPopup("Vous êtes ici").openPopup();
    map.setView([userLat, userLon], 15);
    spawnDrivers(userLat, userLon, 8);
  });
} else {
  alert("Géolocalisation non supportée !");
  spawnDrivers(userLat, userLon, 8);
}

// Réservation
document.getElementById("orderBtn").addEventListener("click", function(){
  const nom = document.getElementById("name").value;
  const tel = document.getElementById("phone").value;
  const depart = document.getElementById("departure").value;
  const destination = document.getElementById("destination").value;

  if(!nom || !tel || !depart || !destination){
    alert("Veuillez remplir tous les champs !");
    return;
  }

  // Popup intégré sur la carte avec confirmation
  L.popup({closeOnClick:true})
    .setLatLng([userLat, userLon])
    .setContent(`<div style="font-weight:bold; font-size:16px;">✅ Commande reçue !<br>Nom: ${nom}<br>Départ: ${depart}<br>Destination: ${destination}<br>Un chauffeur est en route.</div>`)
    .openOn(map);
});
</script>
</body>
</html>
